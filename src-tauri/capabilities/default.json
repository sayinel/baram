{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main window and file-mode windows",
  "windows": ["main", "file-*"],
  "permissions": [
    "core:default",
    "core:window:allow-create",
    "core:webview:allow-create-webview-window",
    "opener:default",
    "dialog:default",
    "clipboard-manager:allow-write-image"
  ]
}
