{
  "name": "baram",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "packageManager": "npm@11.9.0",
  "engines": {
    "node": "24.14.x",
    "npm": "11.9.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "npm run version:check && npm run lint:frontend",
    "lint:frontend": "npm run format:check && npm run lint:ts && npm run lint:css && npm run typecheck && npm run knip:ci",
    "lint:ts": "eslint src/ --max-warnings=0",
    "lint:css": "stylelint 'src/**/*.css' --max-warnings=0",
    "rust:fmt": "cargo fmt --manifest-path src-tauri/Cargo.toml --check",
    "rust:prepare": "npm run build",
    "rust:_clippy": "cargo clippy --manifest-path src-tauri/Cargo.toml --all-targets -- -D warnings",
    "rust:_test": "cargo test --manifest-path src-tauri/Cargo.toml",
    "rust:clippy": "npm run rust:prepare && npm run rust:_clippy",
    "rust:test": "npm run rust:prepare && npm run rust:_test",
    "rust:check": "npm run rust:fmt && npm run rust:prepare && npm run rust:_clippy && npm run rust:_test",
    "check": "npm run lint && npm run test",
    "verify:ci": "npm run check && npm run rust:check",
    "format": "prettier --write 'src/**/*.{ts,tsx,css}'",
    "format:check": "prettier --check 'src/**/*.{ts,tsx,css}'",
    "knip": "knip",
    "knip:ci": "knip --reporter compact",
    "tokens:build": "npx tsx style-dictionary.config.ts",
    "tokens:export": "npx tsx scripts/export-tokens-studio.ts",
    "audit:css-vars": "npx tsx scripts/audit-css-vars.ts",
    "version:check": "node ./scripts/check-version-sync.mjs",
    "prepare": "husky"
  },
  "dependencies": {
    "@codemirror/commands": "^6.10.3",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-go": "^6.0.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.5",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-php": "^6.0.2",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/language": "^6.12.2",
    "@codemirror/legacy-modes": "^6.5.2",
    "@codemirror/state": "^6.5.4",
    "@codemirror/view": "^6.40.0",
    "@floating-ui/dom": "^1.7.6",
    "@tailwindcss/vite": "^4.1.18",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-opener": "^2",
    "@tiptap/extension-document": "^3.22.2",
    "@tiptap/extension-dropcursor": "^3.22.2",
    "@tiptap/extension-gapcursor": "^3.22.2",
    "@tiptap/extension-hard-break": "^3.22.2",
    "@tiptap/extension-history": "^3.22.2",
    "@tiptap/extension-placeholder": "^3.22.2",
    "@tiptap/extension-table": "^3.22.2",
    "@tiptap/extension-table-cell": "^3.22.2",
    "@tiptap/extension-table-header": "^3.22.2",
    "@tiptap/extension-table-row": "^3.22.2",
    "@tiptap/extension-text": "^3.22.2",
    "@tiptap/pm": "^3.19.0",
    "@tiptap/react": "^3.22.2",
    "@tiptap/suggestion": "^3.22.2",
    "@types/mdast": "^4.0.4",
    "codemirror-lang-latex": "^0.2.0",
    "cytoscape": "^3.33.1",
    "cytoscape-fcose": "^2.2.0",
    "dompurify": "^3.3.3",
    "fast-diff": "^1.3.0",
    "katex": "^0.16.28",
    "lucide-react": "^0.577.0",
    "mdast-util-from-markdown": "^2.0.2",
    "mdast-util-gfm": "^3.1.0",
    "mdast-util-to-markdown": "^2.1.2",
    "mdast-util-to-string": "^4.0.0",
    "mermaid": "^11.12.2",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "remark-frontmatter": "^5.0.0",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "remark-parse": "^11.0.0",
    "remark-stringify": "^11.0.0",
    "tailwindcss": "^4.1.18",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^10.0.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/cytoscape": "^3.31.0",
    "@types/katex": "^0.16.8",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^5.1.4",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-perfectionist": "^5.8.0",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "husky": "^9.1.7",
    "jsdom": "29.0.1",
    "knip": "^6.0.2",
    "lint-staged": "^16.3.2",
    "prettier": "^3.8.2",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "style-dictionary": "^5.4.0",
    "stylelint": "^17.7.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-config-standard": "^40.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.1",
    "vite": "^7.3.2",
    "vitest": "^4.1.0"
  }
}
